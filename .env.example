# ─── Application ─────────────────────────────────
APP_NAME=KISAN_DRISHTI
APP_ENV=development
SECRET_KEY=kisan_drishti_super_secret_signing_key_2026_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────
POSTGRES_DB=kisan_drishti
POSTGRES_USER=kdadmin
POSTGRES_PASSWORD=KisanDrishti2024!
DATABASE_URL=postgresql+asyncpg://kdadmin:KisanDrishti2024!@postgres:5432/kisan_drishti
DATABASE_URL_SYNC=postgresql://kdadmin:KisanDrishti2024!@postgres:5432/kisan_drishti

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO ───────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=kdminio
MINIO_ROOT_PASSWORD=MinioKisan2024!
MINIO_BUCKET_RASTERS=kd-rasters
MINIO_BUCKET_MODELS=kd-models
MINIO_BUCKET_OUTPUTS=kd-outputs

# ─── MongoDB ─────────────────────────────────────
MONGODB_URL=mongodb://kdmongo:MongoKisan2024!@mongodb:27017/kisan_drishti_logs
MONGO_USER=kdmongo
MONGO_PASSWORD=MongoKisan2024!

# ─── Google Earth Engine ─────────────────────────
GEE_PROJECT_ID=kisan-drishti-gee
GEE_SERVICE_ACCOUNT=gee-sa@kisan-drishti-gee.iam.gserviceaccount.com
GEE_KEY_FILE=/app/gee_credentials.json
USE_SAMPLE_DATA=true   # Set false to use real GEE data

# ─── Sentinel Hub ────────────────────────────────
SENTINEL_HUB_CLIENT_ID=sh-client-id
SENTINEL_HUB_CLIENT_SECRET=sh-client-secret

# ─── IMD Weather API ─────────────────────────────
IMD_API_KEY=imd-api-key
IMD_API_URL=https://api.imd.gov.in/weather

# ─── Twilio (SMS + WhatsApp) ─────────────────────
TWILIO_ACCOUNT_SID=twilio-account-sid
TWILIO_AUTH_TOKEN=twilio-auth-token
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Notification Settings ───────────────────────
ENABLE_SMS=false
ENABLE_WHATSAPP=false
ENABLE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@kisandrishti.gov.in
SMTP_PASSWORD=app-password
ADMIN_EMAIL=admin@kisandrishti.gov.in

# ─── Grafana ─────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── MapTiler (Map tiles) ────────────────────────
MAPTILER_KEY=demo_key

# ─── MLflow ──────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Pilot Area Configuration ────────────────────
PILOT_AREA_NAME=Chambal_Command_Area_MP
PILOT_AREA_STATE=Madhya Pradesh
PILOT_AREA_DISTRICT=Morena
PILOT_SEASON=Rabi-2024-25
PILOT_CROP_SEASON_START=2024-11-01
PILOT_CROP_SEASON_END=2025-04-30
